# Railway → Service → Variables (აქ ჩაწერილი ყველაფერი ხდება process.env)

# სავალდებულო — MongoDB Atlas connection string (ან Railway Mongo plugin)
# Atlas → Network Access: 0.0.0.0/0 (ან Railway IP) თორემ „ვერ უკავშირდება“
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/aphoteka_db?retryWrites=true&w=majority

# სავალდებულო პროდაქშენში — გრძელი შემთხვევითი string (JWT ხელმოწერა)
JWT_SECRET=change-me-long-random-secret

# ფრონტის დომენი(ები) CORS-ისთვის — მძიმით. არა Railway URL.
# მაგ: https://aphoteka-admin-panel.vercel.app
# ცარიელი დატოვება → კოდი ნებისმიერ Origin-ს უშვებს (ნაკლებად მკაცრი)
# CORS_ORIGIN=https://aphoteka-admin-panel.vercel.app,http://localhost:3000

# Railway თავად აყენებს — ჩვეულებრივ ხელით არ წერო
# PORT=3000

# BOG გადახდა — სავალდებულოა საჯარო HTTPS, რომ ბანკმა callback მიაწოდოს Nest-ს
# ორიგინი უპრეფიქსო (არა .../api): callback იქნება {NEST_PUBLIC_URL}/api/payments/bog/callback
NEST_PUBLIC_URL=https://your-api.up.railway.app
# ან სრული callback (ერთ-ერთი საკმარისია):
# BOG_CALLBACK_URL=https://your-api.up.railway.app/api/payments/bog/callback
# ლოკალური Nest + ტელეფონი: ngrok http 3001 → NEST_PUBLIC_URL=https://xxxx.ngrok-free.app

# სატესტო გადახდა: BOG-ს ეგზავნება მხოლოდ ეს თანხა (₾), არა შეკვეთის რეალური ჯამი. პროდაქშენზე არ ჩართო.
# BOG_TEST_PAY_AMOUNT_GEL=1

# Balance — Nest (მობილური რეგისტრაცია → Exchange Clients)
# ნაგულისხმევი იუზერი/პაროლი: მონორეპოს `src/lib/balance-default-auth.ts` (Next `balanceClient` + Nest); env უპირატესოა.
# პუბლიკაციის ID ცარიელი დატოვება → ნაგულისხმევად 7596 (იგივე რაც Next `balancePublicationTarget.ts`)
# BALANCE_PUBLICATION_ID=7596
# — Basic Auth (ერთ-ერთი წყვილი საკმარისია, იგივე სახელები რაც Next `.env.local`-ში):
# BALANCE_API_USER=
# BALANCE_API_PASSWORD=
# ან (Next `balanceClient`-ის ტრადიციული სახელები / ალტერნატივები):
# BALANCE_USER_NAME=
# BALANCE_USER_PASSWORD=
# BALANCE_USERNAME=          # იგივე რაც USER_NAME
# BALANCE_PASSWORD=          # იგივე რაც USER_PASSWORD
# პაროლში + ან # — ბრჭყალებში: BALANCE_USER_PASSWORD="1985+Mai"
# ან მთელი ჰედერი: BALANCE_AUTHORIZATION=Basic ... ან Bearer ...
# სრული URL override: BALANCE_CLIENTS_POST_URL=https://cloud.balance.ge/sm/a/Balance/7596/hs/Exchange/Clients
# BALANCE_EXCHANGE_MODE=a
# BALANCE_EXCHANGE_CLIENTS_RESOURCE=Clients
# პროდუქტების სიაში ცოცხალი ფასდაკლება (GET); ცარიელი → sm/{a|o}/Balance/{BALANCE_PUBLICATION_ID}/hs/Exchange/Discounts
# BALANCE_DISCOUNTS_URL=

# Next admin (Vercel) — ხშირად იქვეა Balance proxy; იხილე `src/lib/api/balanceClient.ts`
# BALANCE_USER_NAME, BALANCE_USER_PASSWORD, BALANCE_PUBLICATION_ID, ...
#
# BOG `completed` → Balance Exchange Sale (PUT), იგივე Basic Auth რაც Clients-ზე
#
# დინამიკა (ხელით საწყობის გარეშე): `Warehouse` + სერია იღება პროდუქტის `balanceStockBreakdown`-იდან;
# შეკვეთის `warehouseId` → Mongo საწყობის სახელი ემთხვევა `balanceWarehouseName`-ს (თუ ემთხვევა — იმ ხაზიდან UUID/სახელი).
# სხვადასხვა საწყობის ხაზები → ერთ PUT მასივში რამდენიმე Sale დოკუმენტი (თითო საწყობზე ერთი).
# `Item` = `balanceNomenclatureItemUid` (GUID, Items სინქი) — SKU სახელით Balance ხშირად არ იცნობს („ნომენკლატურა“ ცარიელია).
# `Unit` — უპირატესად GUID (`unitOfMeasure`); Item=ნომენკლატურის GUID-ზე ხშირად ცარიელი დატოვებაა (Balance: Item-იდან). Item=SKU-სას ტექსტური ფოლბექი (`itemUnit` / `BALANCE_SALE_ITEM_UNIT`), რომ „ერთ.“ არ იყოს ცარიელი. `IncomeAccount` ხაზზე: პროდუქტის `balanceRevenuesAccount` ან დოკუმენტის `revenueAccount`.
# `VATRate` ხაზზე: Balance კატალოგის **GUID**. რეზოლვი (per-line):
#   1) პროდუქტის `balanceVatRateUid` (Mongo),
#   2) taxation-map-ი — `BALANCE_SALE_VAT_RATE_REGULAR` / `_ZERO` / `_WITHOUT_VAT` / `_EXEMPT` (inline: itemVatRateMap),
#   3) global fallback `BALANCE_SALE_ITEM_VAT_RATE` (inline: itemVatRate).
# არა-GUID ტექსტის დასაშვებად: `BALANCE_SALE_ITEM_VAT_RATE_ALLOW_NON_GUID=1` (რისკიანი; Balance ხშირად მაინც არ იღებს).
# წინასწარი assemble-ბლოკი (ნომენკლატურა / საქონლის ანგარიშები): `BALANCE_SALE_STRICT_ASSEMBLE=1` — PUT არ გაიგზავნება ცარიელი სავალდებულეებით. ნაგულისხმევად გამორთული — Balance-ის პასუხი/ლოგი.
# საქონლის ხაზი (`Item`=GUID): სავალდებული `AccountNumber`, `ExpensesAccount`; VAT-ზე — `VATPayableAccount` (თუ VATTaxable ≠ „არ იბეგრება დღგ-ით“).
# ფოლბექები: `itemGoodsInventoryAccount`, `itemGoodsExpensesAccount`, `itemGoodsVatPayableAccount` ან env BALANCE_SALE_ITEM_GOODS_* + დოკუმენტის expensesAccount, vatAccount.
# დოკუმენტი: VATTaxable / OperationType / VATArticle — ნაგულ. enum ტექსტები ინლაინში (ან env BALANCE_SALE_VAT_TAXABLE, BALANCE_SALE_OPERATION_TYPE, BALANCE_SALE_VAT_ARTICLE).
#
# Sale (BOG → Balance PUT): ძირითადი კონფიგი — `src/config/balance-sale-inline.ts` (იქვე შეავსე receivablesAccount, revenueAccount, სურვილისამებრ Payment და ა.შ.).
# ტესტი გადახდის გარეშე: ინლაინში `testPutEnabled: true` ან BALANCE_SALE_TEST_PUT_ENABLED=1 →
#   POST /api/payments/bog/test-balance-sale  JSON `{"orderId":"<Mongo _id>"}`  (მხოლოდ Balance PUT),
#   POST /api/orders/:id/payment/bog/dev-simulate-completed  JWT — სტატიკური BOG `completed` + იგივე Balance Sale (მობილური დევ ღილაკი).
# Sale PUT სხეულის ლოგი: balance-sale-inline.ts → logSaleRequestBody ან BALANCE_LOG_SALE_REQUEST=1/0; ოფციონალური: BALANCE_LOG_SALE_REQUEST_MAX_CHARS=
# იგივე სახელის env ჯერ კიდევ მუშაობს ფოლბექად, თუ ინლაინში ველი ცარიელია.
# BALANCE_SALE_RECEIVABLES_ACCOUNT=1210  BALANCE_SALE_REVENUE_ACCOUNT=6110  BALANCE_SALE_ITEM_VAT_RATE=<დღგ-ის განაკვეთის GUID>  BALANCE_SALE_PUT_URL=
# BALANCE_SALE_VAT_RATE_REGULAR=<ჩვეულებრივი დღგ GUID>   BALANCE_SALE_VAT_RATE_ZERO=<ნულოვანი GUID>
# BALANCE_SALE_VAT_RATE_WITHOUT_VAT=<დღგ-ის გარეშე GUID>  BALANCE_SALE_VAT_RATE_EXEMPT=<დაუბეგრავი GUID>
# BALANCE_EXCHANGE_SALE_RESOURCE=Sale  BALANCE_LOG_EXCHANGE_SALE=0
