# ═══════════════════════════════════════════════════════════════════
# Railway → Service → Variables (აქ ჩაწერილი ყველაფერი ხდება process.env)
# ═══════════════════════════════════════════════════════════════════

# სავალდებულო — MongoDB Atlas connection string (ან Railway Mongo plugin)
# Atlas → Network Access: 0.0.0.0/0 (ან Railway IP) თორემ „ვერ უკავშირდება“
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/aphoteka_db?retryWrites=true&w=majority

# სავალდებულო პროდაქშენში — გრძელი შემთხვევითი string (JWT ხელმოწერა)
JWT_SECRET=change-me-long-random-secret

# ფრონტის დომენი(ები) CORS-ისთვის — მძიმით. არა Railway URL.
# მაგ: https://aphoteka-admin-panel.vercel.app
# ცარიელი დატოვება → კოდი ნებისმიერ Origin-ს უშვებს (ნაკლებად მკაცრი)
# CORS_ORIGIN=https://aphoteka-admin-panel.vercel.app,http://localhost:3000

# Railway თავად აყენებს — ჩვეულებრივ ხელით არ წერო
# PORT=3000

# BOG გადახდა — სავალდებულოა საჯარო HTTPS, რომ ბანკმა callback მიაწოდოს Nest-ს
# ორიგინი უპრეფიქსო (არა .../api): callback იქნება {NEST_PUBLIC_URL}/api/payments/bog/callback
NEST_PUBLIC_URL=https://your-api.up.railway.app
# ან სრული callback (ერთ-ერთი საკმარისია):
# BOG_CALLBACK_URL=https://your-api.up.railway.app/api/payments/bog/callback
# ლოკალური Nest + ტელეფონი: ngrok http 3001 → NEST_PUBLIC_URL=https://xxxx.ngrok-free.app

# სატესტო გადახდა: BOG-ს ეგზავნება მხოლოდ ეს თანხა (₾), არა შეკვეთის რეალური ჯამი. პროდაქშენზე არ ჩართო.
# BOG_TEST_PAY_AMOUNT_GEL=1

# ═══════════════════════════════════════════════════════════════════
# Vercel (Next admin) — Balance proxy; Nest Railway-ზე არ სჭირდება:
# BALANCE_USER_NAME, BALANCE_USER_PASSWORD, BALANCE_PUBLICATION_ID, ...
# ═══════════════════════════════════════════════════════════════════
