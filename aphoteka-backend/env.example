# Railway (ან სხვა hosting) — დააკოპირე სახელები Variables-ში
# MongoDB Atlas ან Railway MongoDB plugin → connection string
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/aphoteka_db?retryWrites=true&w=majority

# JWT ხელმოწერა (გრძელი შემთხვევითი string)
JWT_SECRET=change-me-long-random-secret

# Railway თავად აყენებს PORT-ს — ხელით ჩაწერა ჩვეულებრივ არ სჭირდება
# PORT=3000

# CORS დამატებითი დომენები (კომით გამოყოფილი), მაგ. Expo web / სხვა admin
# CORS_ORIGINS=https://myapp.example.com
