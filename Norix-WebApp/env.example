# Norix WebApp — copy to .env.local
#
# Backend (aphoteka-backend) უნდა გაეშვას პორტ 3000-ზე:
#   cd aphoteka-backend && npm run start:dev
#
# WebApp dev:
#   npm run dev   → http://localhost:3003

# ლოკალური Nest API
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# პროდაქშენზე (Railway):
# NEXT_PUBLIC_API_URL=https://aphoteka-admin-panel-production.up.railway.app/api
